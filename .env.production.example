# Public deployment settings
DOMAIN=osdaily.example.org
ADMIN_TOKEN=change-this-long-random-token
CONTACT_EMAIL=opensource-daily@example.org
SCHEDULE_TIME=06:00

# Optional webhook notification
DAILY_WEBHOOK_URL=
DAILY_WEBHOOK_TYPE=generic

# Optional enrichment
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
TRANSLATION_PROVIDER=openai
TRANSLATE_ENABLED=true
REWRITE_SUMMARY_ENABLED=true

# Optional Twitter/X official API
TWITTER_BEARER_TOKEN=
TWITTER_OPEN_SOURCE_KOL_LIST_ID=
