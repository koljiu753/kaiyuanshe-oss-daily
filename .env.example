# Optional. Used by the future Twitter/X official API collector.
TWITTER_BEARER_TOKEN=
TWITTER_OPEN_SOURCE_KOL_LIST_ID=

# Optional. Used by webhook notification.
DAILY_WEBHOOK_URL=
DAILY_WEBHOOK_TYPE=generic

# Optional. Used only when running with --translate.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
TRANSLATION_PROVIDER=openai
TRANSLATE_ENABLED=false
REWRITE_SUMMARY_ENABLED=false

# Optional. Identify this crawler in User-Agent.
CONTACT_EMAIL=opensource-daily@example.org

# Optional. Protect the local admin site when exposed beyond localhost.
ADMIN_TOKEN=

# Optional. Used by the built-in scheduler when serving the admin site.
SCHEDULE_TIME=06:00
